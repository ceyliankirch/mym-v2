generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── TABLE SÉJOURS ──────────────────────────────────────────────
model Sejour {
  id          String        @id @default(cuid())
  titre       String
  lieu        String
  dateDebut   DateTime
  dateFin     DateTime
  prix        Float
  places      Int
  statut      String        @default("Brouillon")
  
  trancheAge  String?       // ex: "13-17 ans"
  saison      String?       // ex: "Été"
  imageUrl    String?       // Le lien vers l'image
  
  createdAt   DateTime      @default(now())
  inscriptions Inscription[]
}

// ─── TABLE CLIENTS / FAMILLES ───────────────────────────────────
model Client {
  id          String        @id @default(cuid())
  nom         String
  prenom      String
  email       String        @unique
  telephone   String?
  createdAt   DateTime      @default(now())

  // Relation : Un client peut avoir plusieurs inscriptions
  inscriptions Inscription[]
}

// ─── TABLE INSCRIPTIONS (La table de liaison) ───────────────────
model Inscription {
  id          String   @id @default(cuid())
  statut      String   @default("En attente") // En attente, Validé, Annulé
  montantPaye Float    @default(0)
  createdAt   DateTime @default(now())

  // Clés étrangères pour lier le Client et le Séjour
  sejourId    String
  sejour      Sejour   @relation(fields: [sejourId], references: [id])
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
}